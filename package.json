{
  "name": "thinkboard",
  "version": "1.0.0",
  "description": "A real-time collaborative whiteboard demonstrating distributed systems concepts: WebSockets, CRDTs, presence systems, horizontal scaling, and event streaming.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:scale": "docker-compose -f docker-compose.yml -f docker-compose.scale.yml up -d --scale app=3",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "websocket",
    "collaborative",
    "whiteboard",
    "crdt",
    "distributed-systems",
    "real-time",
    "presence"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "uuid": "^9.0.0",
    "ioredis": "^5.3.2"
  }
}
