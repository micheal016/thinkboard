# Server
PORT=3000
NODE_ENV=development

# Redis (optional - defaults to in-memory mode if not set)
REDIS_URL=redis://localhost:6379

# Scaling mode: 'memory' (single instance) or 'redis' (multi-instance)
ADAPTER_MODE=memory

# Presence
PRESENCE_HEARTBEAT_INTERVAL=2000
PRESENCE_TIMEOUT=5000

# Room settings
MAX_OPERATIONS_PER_ROOM=10000
MAX_USERS_PER_ROOM=50
